# Atlan LiteLLM proxy — same pattern used by experiment/ and job-search/
# Copy this file to .env and fill in real values, or export in your shell.

LITELLM_BASE_URL=https://...    # Atlan's LiteLLM proxy URL
LITELLM_API_KEY=sk-...           # Your LiteLLM proxy API key

# Atlan context integration (optional — discovery primes the agent with
# established context when these are set AND --atlan-* CLI / MCP args
# name a scope. Discovery runs in probe-only mode if absent or empty).
# ATLAN_BASE_URL can be overridden per-session via --atlan-tenant.
ATLAN_BASE_URL=https://ces.atlan.com
ATLAN_API_KEY=                   # Service-account API key with read scope
